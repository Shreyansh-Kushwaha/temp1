# Frontend → Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend — Anthropic
ANTHROPIC_API_KEY=

# Backend — Wise Portal
WISE_API_URL=
WISE_API_KEY=

# Backend — Supabase Postgres (relational data: reports, versions, opt-ins,
# audio summaries metadata, etc.). Get the value from:
#   Supabase Dashboard → Project Settings → Database → Connection string
#                      → "Transaction Pooler" tab (port 6543)
# Format: postgresql://postgres.<PROJECT-REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Backend — Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Backend — WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Slack Bot
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_MANAGER_USER_ID=

# Backend — Supabase Storage (audio summaries + report PDFs)
SUPABASE_URL=
SUPABASE_KEY=

# Backend — Frontend URL the PDF renderer hits to capture /ptm/{id}/print
# Defaults to http://localhost:3000 if unset.
FRONTEND_URL=http://localhost:3000

# Backend — TTS for audio summaries.
# TTS_PROVIDER: gtts | elevenlabs | huggingface | browser
TTS_PROVIDER=gtts

# ElevenLabs (when TTS_PROVIDER=elevenlabs). Default voice is Daniel (calm male).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
